# OpenAI
OPENAI_API_KEY=sk-...
# Must support the Responses API + hosted WebSearchTool
DEFAULT_MODEL_NAME=gpt-4.1

# Optional: enables automatic fallback to Gemini when OpenAI rate-limits
# (used for the Sales Agent + on-topic guardrail only, not the Researcher,
# which needs OpenAI's hosted WebSearchTool).
GEMINI_API_KEY=xxxx...
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# SMTP (e.g. Gmail: use an App Password, not your normal password)
EMAIL_ADDRESS=atifxxxxxxh@gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_APP_PASSWORD=xxxx

# Optional: Google Sheets CRM (if unset, the CRM tools return a clear error
# instead of the app failing to start). Requires a GCP service account with
# the Sheets API enabled, whose client_email has been shared as Editor on
# the target spreadsheet. GOOGLE_SHEET_ID is the id from the sheet's URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json
GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_WORKSHEET_NAME=Leads

# On hosts with no file upload for secrets (e.g. HF Spaces), paste the full
# service_account.json content here instead and leave the file absent locally;
# config.py writes it to GOOGLE_APPLICATION_CREDENTIALS on startup.
GOOGLE_SERVICE_ACCOUNT_JSON={
  "type": "service_account",
  "project_id": "xxxxx",
  "private_key_id": "......",
  "private_key": "-----BEGIN PRIVATE KEY-----\nxxxxxxxxxxxxx=\n-----END PRIVATE KEY-----\n",
  "client_email": "....iam.gserviceaccount.com",
  "client_id": "....",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "...",
  "universe_domain": "googleapis.com"
}
